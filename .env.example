# Vaipakam keeper bot — environment template.
#
# Copy to `.env` and fill in. Every variable below is required unless
# explicitly marked optional. The bot exits at startup with a clear
# error when a required value is missing or malformed.

# ─── Keeper EOA — the address that submits triggerLiquidation txs.
# Must be funded with native gas on every chain you operate against.
# Losing the key = losing the bonus, not user funds (the diamond
# never holds anything for the keeper). Treat as a hot wallet.
KEEPER_PRIVATE_KEY=0x...

# ─── Chains to operate on. Comma-separated chain IDs. Each chain
# below requires both the diamond address and a paid RPC URL set.
# Public RPCs WILL rate-limit; use Alchemy / Infura / QuickNode.
CHAIN_IDS=8453,1

# ─── Per-chain config (one set of three lines per chain in CHAIN_IDS).
# CHAIN_<ID>_DIAMOND   — the Vaipakam Diamond proxy on this chain.
# CHAIN_<ID>_RPC_URL   — paid RPC endpoint URL.
# CHAIN_<ID>_LOAN_IDS  — optional comma-separated loan IDs to monitor.
#                        Leave blank to scan ALL active loans (more
#                        RPC calls per tick; appropriate for ops who
#                        want to compete for any liquidation).
CHAIN_8453_DIAMOND=0x...
CHAIN_8453_RPC_URL=https://base-mainnet.g.alchemy.com/v2/...
CHAIN_8453_LOAN_IDS=
CHAIN_1_DIAMOND=0x...
CHAIN_1_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/...
CHAIN_1_LOAN_IDS=

# ─── Aggregator API keys (off-chain quote routes).
# Either or both can be left blank — the bot still works using
# on-chain UniV3 + Balancer V2 routes only, just with a smaller
# search space and possibly worse fills on long-tail pairs.
ZEROEX_API_KEY=
ONEINCH_API_KEY=

# ─── Tick interval — how often the bot polls each chain. In seconds.
# Cloudflare-Workers cron pattern is 5 minutes; for self-hosted
# competitors 30-60 seconds is more typical.
POLL_INTERVAL_SECONDS=60

# ─── Slippage cap, in basis points. Defaults to 600 (6%) to match
# the on-chain protocol ceiling. Lower = more reverts under slippage,
# higher = more MEV captured by the swap. Almost everyone leaves at 600.
SLIPPAGE_BPS=600

# ─── Minimum profit gate, in USD (8-decimal scaled). The bot skips
# any liquidation whose estimated bonus is below this floor — useful
# on high-gas chains where a small position would lose money to net
# fees. Set to 0 to attempt every eligible liquidation.
MIN_PROFIT_USD_8DEC=10000000000

# ─── Logging.
# LOG_LEVEL=debug surfaces every probe + RPC call.
# LOG_LEVEL=info shows tick + liquidation submissions only.
LOG_LEVEL=info
